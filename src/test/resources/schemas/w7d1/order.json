{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "orderId",
    "customerId",
    "cartId",
    "status",
    "couponCode",
    "subtotalPaise",
    "discountPaise",
    "totalPaise",
    "address",
    "createdAt",
    "items"
  ],
  "properties": {
    "id": { "type": "integer", "minimum": 1 },
    "orderId": { "type": "integer", "minimum": 1 },
    "customerId": { "type": "integer", "minimum": 1 },
    "cartId": { "type": "integer", "minimum": 1 },
    "status": { "type": "string", "enum": ["PLACED", "CANCELLED"] },
    "couponCode": { "type": ["string", "null"] },
    "subtotalPaise": { "type": "integer", "minimum": 1 },
    "discountPaise": { "type": "integer", "minimum": 0 },
    "totalPaise": { "type": "integer", "minimum": 1 },
    "address": { "type": "string", "minLength": 10, "maxLength": 240 },
    "createdAt": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sku", "name", "qty", "unitPricePaise", "lineTotalPaise"],
        "properties": {
          "sku": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "qty": { "type": "integer", "minimum": 1 },
          "unitPricePaise": { "type": "integer", "minimum": 1 },
          "lineTotalPaise": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
